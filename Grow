-- LOADING SCREEN CONFIG --
getgenv().LoadingScreen = true
getgenv().LoadingConfig = {
    Duration = 120, -- Set to 120 seconds (2 minutes)
    BackgroundColor = Color3.fromRGB(15, 10, 20),
    TextColor       = Color3.fromRGB(255, 255, 255),
    Font            = Enum.Font.GothamBold,
    BarColor        = Color3.fromRGB(180, 80, 255),
    BarBackColor    = Color3.fromRGB(40, 20, 60),
    FadeTime        = 1,
}

-- LOADING SCREEN LOGIC --
if getgenv().LoadingScreen then
    task.spawn(function()
        local Players = game:GetService("Players")
        local TweenService = game:GetService("TweenService")
        local player = Players.LocalPlayer
        local playerGui = player:WaitForChild("PlayerGui")

        local gui = Instance.new("ScreenGui", playerGui)
        gui.Name = "StarLoadingScreen"
        gui.IgnoreGuiInset = true
        gui.DisplayOrder = 9999

        -- Compact Box Container
        local frame = Instance.new("Frame", gui)
        frame.Size = UDim2.new(0, 450, 0, 240)
        frame.Position = UDim2.new(0.5, -225, 0.5, -120)
        frame.BackgroundColor3 = getgenv().LoadingConfig.BackgroundColor
        frame.BorderSizePixel = 0
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 12)
        Instance.new("UIStroke", frame).Color = getgenv().LoadingConfig.BarColor

        local title = Instance.new("TextLabel", frame)
        title.Size = UDim2.new(1, 0, 0, 50)
        title.Position = UDim2.new(0, 0, 0.15, 0)
        title.BackgroundTransparency = 1
        title.Text = "STAR SCRIPTS"
        title.TextColor3 = getgenv().LoadingConfig.TextColor
        title.Font = getgenv().LoadingConfig.Font
        title.TextScaled = true

        local discord = Instance.new("TextLabel", frame)
        discord.Size = UDim2.new(1, 0, 0, 30)
        discord.Position = UDim2.new(0, 0, 0.4, 0)
        discord.BackgroundTransparency = 1
        discord.Text = "discord.gg/EYAWVkf7x"
        discord.TextColor3 = Color3.fromRGB(150, 150, 150)
        discord.Font = Enum.Font.Gotham
        discord.TextScaled = true

        local barBack = Instance.new("Frame", frame)
        barBack.Size = UDim2.new(0.8, 0, 0, 12)
        barBack.Position = UDim2.new(0.1, 0, 0.7, 0)
        barBack.BackgroundColor3 = getgenv().LoadingConfig.BarBackColor
        barBack.BorderSizePixel = 0
        Instance.new("UICorner", barBack).CornerRadius = UDim.new(1, 0)

        local barFill = Instance.new("Frame", barBack)
        barFill.Size = UDim2.new(0, 0, 1, 0)
        barFill.BackgroundColor3 = getgenv().LoadingConfig.BarColor
        barFill.BorderSizePixel = 0
        Instance.new("UICorner", barFill).CornerRadius = UDim.new(1, 0)

        local percent = Instance.new("TextLabel", frame)
        percent.Size = UDim2.new(0, 100, 0, 30)
        percent.Position = UDim2.new(0.5, -50, 0.8, 0)
        percent.BackgroundTransparency = 1
        percent.Text = "0%"
        percent.TextColor3 = getgenv().LoadingConfig.TextColor
        percent.Font = Enum.Font.Code
        percent.TextScaled = true

        -- Animation
        TweenService:Create(barFill, TweenInfo.new(getgenv().LoadingConfig.Duration, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 1, 0)}):Play()

        task.spawn(function()
            local start = os.clock()
            while os.clock() - start < getgenv().LoadingConfig.Duration do
                percent.Text = math.floor(((os.clock() - start) / getgenv().LoadingConfig.Duration) * 100) .. "%"
                task.wait(0.5)
            end
            percent.Text = "100%"
        end)

        task.wait(getgenv().LoadingConfig.Duration + 0.5)
        
        -- Fade Out
        local info = TweenInfo.new(getgenv().LoadingConfig.FadeTime)
        TweenService:Create(frame, info, {BackgroundTransparency = 1}):Play()
        for _, v in pairs(frame:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("Frame") then
                TweenService:Create(v, info, {TextTransparency = 1}):Play()
            end
        end
        
        task.wait(getgenv().LoadingConfig.FadeTime)
        gui:Destroy()
    end)
end

