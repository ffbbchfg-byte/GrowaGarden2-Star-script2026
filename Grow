-- LOADING SCREEN LOGIC --
if getgenv().LoadingScreen then
    task.spawn(function()
        local Players = game:GetService("Players")
        local TweenService = game:GetService("TweenService")
        local player = Players.LocalPlayer
        local playerGui = player:WaitForChild("PlayerGui")

        local gui = Instance.new("ScreenGui", playerGui)
        gui.Name = "StarLoadingScreen"
        gui.IgnoreGuiInset = true
        gui.DisplayOrder = 9999
        
        -- Add Blur Effect
        local blur = Instance.new("BlurEffect", game.Lighting)
        blur.Size = 24

        -- Compact Container (80% of screen)
        local frame = Instance.new("Frame", gui)
        frame.Size = UDim2.fromScale(0.8, 0.8) 
        frame.Position = UDim2.fromScale(0.1, 0.1)
        frame.BackgroundColor3 = getgenv().LoadingConfig.BackgroundColor
        frame.BorderSizePixel = 0
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 20)

        local title = Instance.new("TextLabel", frame)
        title.Size = UDim2.new(1, 0, 0, 100)
        title.Position = UDim2.fromScale(0.5, 0.4)
        title.AnchorPoint = Vector2.new(0.5, 0.5)
        title.BackgroundTransparency = 1
        title.Text = "STAR SCRIPTS"
        title.TextColor3 = getgenv().LoadingConfig.TextColor
        title.Font = getgenv().LoadingConfig.Font
        title.TextScaled = true

        local barBack = Instance.new("Frame", frame)
        barBack.Size = UDim2.new(0.6, 0, 0, 20)
        barBack.Position = UDim2.fromScale(0.5, 0.6)
        barBack.AnchorPoint = Vector2.new(0.5, 0.5)
        barBack.BackgroundColor3 = getgenv().LoadingConfig.BarBackColor
        barBack.BorderSizePixel = 0
        Instance.new("UICorner", barBack).CornerRadius = UDim.new(1, 0)
        
        local stroke = Instance.new("UIStroke", barBack)
        stroke.Color = Color3.fromRGB(255, 255, 255)
        stroke.Transparency = 0.5

        local barFill = Instance.new("Frame", barBack)
        barFill.Size = UDim2.fromScale(0, 1)
        barFill.BackgroundColor3 = getgenv().LoadingConfig.BarColor
        barFill.BorderSizePixel = 0
        Instance.new("UICorner", barFill).CornerRadius = UDim.new(1, 0)

        local percent = Instance.new("TextLabel", frame)
        percent.Size = UDim2.new(0, 200, 0, 50)
        percent.Position = UDim2.fromScale(0.5, 0.68)
        percent.AnchorPoint = Vector2.new(0.5, 0.5)
        percent.BackgroundTransparency = 1
        percent.Text = "0%"
        percent.TextColor3 = getgenv().LoadingConfig.BarColor
        percent.Font = Enum.Font.Code
        percent.TextScaled = true

        -- Animation
        TweenService:Create(barFill, TweenInfo.new(getgenv().LoadingConfig.Duration, Enum.EasingStyle.Linear), {Size = UDim2.fromScale(1, 1)}):Play()

        task.spawn(function()
            local start = os.clock()
            while os.clock() - start < getgenv().LoadingConfig.Duration do
                percent.Text = math.floor(((os.clock() - start) / getgenv().LoadingConfig.Duration) * 100) .. "%"
                task.wait(0.5)
            end
            percent.Text = "100%"
        end)

        task.wait(getgenv().LoadingConfig.Duration + 0.5)
        
        -- Fade Out
        local info = TweenInfo.new(getgenv().LoadingConfig.FadeTime)
        TweenService:Create(frame, info, {BackgroundTransparency = 1}):Play()
        for _, obj in pairs(frame:GetDescendants()) do
            if obj:IsA("TextLabel") or obj:IsA("Frame") or obj:IsA("UIStroke") then
                if obj:IsA("UIStroke") then
                    TweenService:Create(obj, info, {Transparency = 1}):Play()
                else
                    TweenService:Create(obj, info, {BackgroundTransparency = 1}):Play()
                end
            end
        end
        
        task.wait(getgenv().LoadingConfig.FadeTime)
        blur:Destroy()
        gui:Destroy()
    end)
end

